<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane prefHeight="600.0" prefWidth="700.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/18" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.biblioteca.controller.BibliotecaController">
   <children>

      <VBox fx:id="panelMenuPrincipal" alignment="CENTER" maxWidth="400.0" maxHeight="500.0" spacing="20.0" styleClass="card">
         <children>
            <Label styleClass="titulo" text="SISTEMA DE BIBLIOTECA" />
            <Button fx:id="btnMenuPersonas" mnemonicParsing="false" text="1. Gestor de Personas" />
            <Button fx:id="btnMenuMateriales" mnemonicParsing="false" text="2. Gestor de Materiales" />
            <Button fx:id="btnMenuPrestamos" mnemonicParsing="false" text="3. Gestor de Préstamos" />
            <Button fx:id="btnSalir" mnemonicParsing="false" text="4. Salir" />
         </children>
      </VBox>

      <VBox fx:id="panelMenuPersonas" alignment="CENTER" maxWidth="400.0" maxHeight="400.0" spacing="20.0" styleClass="card" visible="false">
         <children>
            <Label styleClass="titulo" text="GESTOR DE PERSONAS" />
            <Button fx:id="btnIrAgregarPersona" mnemonicParsing="false" text="1. Agregar Persona" />
            <Button fx:id="btnIrListarPersonas" mnemonicParsing="false" text="2. Ver y Eliminar Personas" />
            <Button fx:id="btnVolverPrincipalDesdePersonas" mnemonicParsing="false" style="-fx-background-color: #d32f2f;" text="Volver al Menú Principal" />
         </children>
      </VBox>

      <VBox fx:id="panelMenuMateriales" alignment="CENTER" maxWidth="400.0" maxHeight="400.0" spacing="20.0" styleClass="card" visible="false">
         <children>
            <Label styleClass="titulo" text="GESTOR DE MATERIALES" />
            <Button fx:id="btnIrAgregarMaterial" mnemonicParsing="false" text="1. Agregar Material" />
            <Button fx:id="btnIrListarMateriales" mnemonicParsing="false" text="2. Ver y Eliminar Materiales" />
            <Button fx:id="btnVolverPrincipalDesdeMateriales" mnemonicParsing="false" style="-fx-background-color: #d32f2f;" text="Volver al Menú Principal" />
         </children>
      </VBox>

      <VBox fx:id="panelMenuPrestamos" alignment="CENTER" maxWidth="400.0" maxHeight="400.0" spacing="20.0" styleClass="card" visible="false">
         <children>
            <Label styleClass="titulo" text="GESTOR DE PRÉSTAMOS" />
            <Button fx:id="btnIrAgregarPrestamo" mnemonicParsing="false" text="1. Prestar Material" />
            <Button fx:id="btnIrListarPrestamos" mnemonicParsing="false" text="2. Ver y Eliminar Préstamos" />
            <Button fx:id="btnVolverPrincipalDesdePrestamos" mnemonicParsing="false" style="-fx-background-color: #d32f2f;" text="Volver al Menú Principal" />
         </children>
      </VBox>

      <VBox fx:id="panelPersona" alignment="CENTER" maxWidth="400.0" maxHeight="500.0" spacing="15.0" styleClass="card" visible="false">
         <children>
            <Label styleClass="titulo" text="- Nueva Persona -" />
            <ComboBox fx:id="cmbTipoPersona" prefWidth="250.0" promptText="Tipo de Persona..." />
            <TextField fx:id="txtNombre" promptText="Nombre" />
            <TextField fx:id="txtApellido" promptText="Apellido" />
            <TextField fx:id="txtCorreo" promptText="Correo" />
            <TextField fx:id="txtTelefono" promptText="Teléfono" />
            <TextField fx:id="txtDatoExtraPersona" promptText="Matrícula / Num. Empleado" />
            <HBox alignment="CENTER" spacing="20.0">
               <children>
                  <Button fx:id="btnGuardarPersona" mnemonicParsing="false" style="-fx-min-width: 120;" text="Guardar" />
                  <Button fx:id="btnVolverPersona" mnemonicParsing="false" style="-fx-min-width: 120; -fx-background-color: #d32f2f;" text="Volver" />
               </children>
            </HBox>
         </children>
      </VBox>

      <VBox fx:id="panelMaterial" alignment="CENTER" maxWidth="400.0" maxHeight="500.0" spacing="15.0" styleClass="card" visible="false">
         <children>
            <Label styleClass="titulo" text="- Nuevo Material -" />
            <ComboBox fx:id="cmbTipoMaterial" prefWidth="250.0" promptText="Tipo de Material..." />
            <TextField fx:id="txtCodigoMaterial" promptText="Código" />
            <TextField fx:id="txtTitulo" promptText="Título" />
            <TextField fx:id="txtAutor" promptText="Autor" />
            <TextField fx:id="txtAnio" promptText="Año" />
            <TextField fx:id="txtEditorial" promptText="Editorial (Solo Libros)" />
            <HBox alignment="CENTER" spacing="20.0">
               <children>
                  <Button fx:id="btnGuardarMaterial" mnemonicParsing="false" style="-fx-min-width: 120;" text="Guardar" />
                  <Button fx:id="btnVolverMaterial" mnemonicParsing="false" style="-fx-min-width: 120; -fx-background-color: #d32f2f;" text="Volver" />
               </children>
            </HBox>
         </children>
      </VBox>

      <VBox fx:id="panelPrestamo" alignment="CENTER" maxWidth="400.0" maxHeight="350.0" spacing="15.0" styleClass="card" visible="false">
         <children>
            <Label styleClass="titulo" text="- Nuevo Préstamo -" />
            <TextField fx:id="txtIdPersonaPrestamo" promptText="ID de la Persona" />
            <TextField fx:id="txtCodigoMaterialPrestamo" promptText="Código del Material" />
            <HBox alignment="CENTER" spacing="20.0">
               <children>
                  <Button fx:id="btnRegistrarPrestamo" mnemonicParsing="false" style="-fx-min-width: 120;" text="Prestar" />
                  <Button fx:id="btnVolverPrestamo" mnemonicParsing="false" style="-fx-min-width: 120; -fx-background-color: #d32f2f;" text="Volver" />
               </children>
            </HBox>
         </children>
      </VBox>

      <VBox fx:id="panelListadoPersonas" alignment="CENTER" maxWidth="600.0" maxHeight="500.0" spacing="15.0" styleClass="card" visible="false">
         <children>
            <Label styleClass="titulo" text="- Lista de Personas -" />
            <ListView fx:id="listPersonas" prefHeight="350.0" prefWidth="550.0" />
            <HBox alignment="CENTER" spacing="20.0">
               <children>
                  <Button fx:id="btnEliminarPersona" mnemonicParsing="false" text="Eliminar Seleccionado" />
                  <Button fx:id="btnVolverListadoPersonas" mnemonicParsing="false" style="-fx-background-color: #d32f2f;" text="Volver" />
               </children>
            </HBox>
         </children>
      </VBox>

      <VBox fx:id="panelListadoMateriales" alignment="CENTER" maxWidth="600.0" maxHeight="500.0" spacing="15.0" styleClass="card" visible="false">
         <children>
            <Label styleClass="titulo" text="- Lista de Materiales -" />
            <ListView fx:id="listMateriales" prefHeight="350.0" prefWidth="550.0" />
            <HBox alignment="CENTER" spacing="20.0">
               <children>
                  <Button fx:id="btnEliminarMaterial" mnemonicParsing="false" text="Eliminar Seleccionado" />
                  <Button fx:id="btnVolverListadoMateriales" mnemonicParsing="false" style="-fx-background-color: #d32f2f;" text="Volver" />
               </children>
            </HBox>
         </children>
      </VBox>

      <VBox fx:id="panelListadoPrestamos" alignment="CENTER" maxWidth="600.0" maxHeight="500.0" spacing="15.0" styleClass="card" visible="false">
         <children>
            <Label styleClass="titulo" text="- Lista de Préstamos -" />
            <ListView fx:id="listPrestamos" prefHeight="350.0" prefWidth="550.0" />
            <HBox alignment="CENTER" spacing="20.0">
               <children>
                  <Button fx:id="btnEliminarPrestamo" mnemonicParsing="false" text="Eliminar Seleccionado" />
                  <Button fx:id="btnVolverListadoPrestamos" mnemonicParsing="false" style="-fx-background-color: #d32f2f;" text="Volver" />
               </children>
            </HBox>
         </children>
      </VBox>

   </children>
</StackPane>