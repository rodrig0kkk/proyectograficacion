<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane prefHeight="600.0" prefWidth="700.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/18" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.biblioteca.controller.BibliotecaController">
   <children>
      <VBox fx:id="panelMenuPrincipal" alignment="CENTER" maxWidth="400.0" maxHeight="500.0" spacing="20.0" styleClass="card">
         <children>
            <Label styleClass="titulo" text="MENÚ BIBLIOTECA" />
            <Button mnemonicParsing="false" onAction="#mostrarPanelMaterial" text="1. Nuevo Material" />
            <Button mnemonicParsing="false" onAction="#mostrarPanelPersona" text="2. Nueva Persona" />
            <Button mnemonicParsing="false" onAction="#mostrarPanelPrestamo" text="3. Prestar Material" />
            <Button mnemonicParsing="false" onAction="#mostrarPanelListados" text="4. Ver Listados" />
            <Button mnemonicParsing="false" onAction="#clicSalir" text="5. Salir" />
         </children>
      </VBox>
      <VBox fx:id="panelPersona" alignment="CENTER" maxWidth="400.0" maxHeight="500.0" spacing="15.0" styleClass="card" visible="false">
         <children>
            <Label styleClass="titulo" text="- Nueva Persona -" />
            <ComboBox fx:id="cmbTipoPersona" prefWidth="250.0" promptText="Tipo de Persona..." />
            <TextField fx:id="txtNombre" promptText="Nombre" />
            <TextField fx:id="txtApellido" promptText="Apellido" />
            <TextField fx:id="txtCorreo" promptText="Correo" />
            <TextField fx:id="txtTelefono" promptText="Teléfono" />
            <TextField fx:id="txtDatoExtraPersona" promptText="Matrícula / Num. Empleado" />
            <HBox alignment="CENTER" spacing="20.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#guardarPersona" style="-fx-min-width: 120;" text="Guardar" />
                  <Button mnemonicParsing="false" onAction="#volverMenu" style="-fx-min-width: 120; -fx-background-color: #d32f2f; -fx-border-color: #ff6659;" text="Volver" />
               </children>
            </HBox>
         </children>
      </VBox>
      <VBox fx:id="panelMaterial" alignment="CENTER" maxWidth="400.0" maxHeight="500.0" spacing="15.0" styleClass="card" visible="false">
         <children>
            <Label styleClass="titulo" text="- Nuevo Material -" />
            <ComboBox fx:id="cmbTipoMaterial" prefWidth="250.0" promptText="Tipo de Material..." />
            <TextField fx:id="txtCodigoMaterial" promptText="Código" />
            <TextField fx:id="txtTitulo" promptText="Título" />
            <TextField fx:id="txtAutor" promptText="Autor" />
            <TextField fx:id="txtAnio" promptText="Año" />
            <TextField fx:id="txtEditorial" promptText="Editorial (Solo Libros)" />
            <HBox alignment="CENTER" spacing="20.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#guardarMaterial" style="-fx-min-width: 120;" text="Guardar" />
                  <Button mnemonicParsing="false" onAction="#volverMenu" style="-fx-min-width: 120; -fx-background-color: #d32f2f; -fx-border-color: #ff6659;" text="Volver" />
               </children>
            </HBox>
         </children>
      </VBox>
      <VBox fx:id="panelPrestamo" alignment="CENTER" maxWidth="400.0" maxHeight="350.0" spacing="15.0" styleClass="card" visible="false">
         <children>
            <Label styleClass="titulo" text="- Nuevo Préstamo -" />
            <TextField fx:id="txtIdPersonaPrestamo" promptText="ID de la Persona" />
            <TextField fx:id="txtCodigoMaterialPrestamo" promptText="Código del Material" />
            <HBox alignment="CENTER" spacing="20.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#registrarPrestamo" style="-fx-min-width: 120;" text="Prestar" />
                  <Button mnemonicParsing="false" onAction="#volverMenu" style="-fx-min-width: 120; -fx-background-color: #d32f2f; -fx-border-color: #ff6659;" text="Volver" />
               </children>
            </HBox>
         </children>
      </VBox>
      <VBox fx:id="panelListados" alignment="CENTER" maxWidth="600.0" maxHeight="550.0" spacing="15.0" styleClass="card" visible="false">
         <children>
            <Label styleClass="titulo" text="- Registros -" />
            <HBox alignment="CENTER" spacing="15.0">
               <children>
                  <Button mnemonicParsing="false" onAction="#verPersonas" style="-fx-min-width: 140;" text="Personas" />
                  <Button mnemonicParsing="false" onAction="#verMateriales" style="-fx-min-width: 140;" text="Materiales" />
                  <Button mnemonicParsing="false" onAction="#verPrestamos" style="-fx-min-width: 140;" text="Préstamos" />
               </children>
            </HBox>
            <ListView fx:id="listViewDatos" prefHeight="350.0" prefWidth="550.0" />
            <Button mnemonicParsing="false" onAction="#volverMenu" style="-fx-background-color: #d32f2f; -fx-border-color: #ff6659;" text="Volver al Menú Principal" />
         </children>
      </VBox>
   </children>
</StackPane>